# Version control
.git
.gitignore
.gitattributes

# Node development artifacts (none exist at runtime)
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn

# Development tooling
eslint.config.mjs
playwright.config.js
.editorconfig
.prettierrc*
.stylelintrc*

# CI and shell scripts (not JS modules used by the runtime)
.github/
bin/

# Documentation only
readme.md
code-of-conduct.md
contributing.md
community/
licenses/

# Test editions (large, not needed at runtime)
editions/test/
editions/testcommonjs/

# Local build output
output/

# OS artifacts
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# IDE directories
.vscode/
.idea/
*.iml
